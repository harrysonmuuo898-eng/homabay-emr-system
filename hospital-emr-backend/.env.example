# ============================================
# Hospital EMR Backend Configuration
# ============================================
# Copy this file to .env and fill in your values

# MongoDB Connection URI
# Local: mongodb://127.0.0.1:27017/hospital_emr
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/hospital_emr
MONGO_URI=mongodb://127.0.0.1:27017/hospital_emr

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration
# For development, set to http://localhost:3000 or the frontend URL
# For production, set to your frontend domain
CORS_ORIGIN=http://localhost:5000

# Authentication Secret
# Generate a strong random string:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-a-long-random-secret

# ============================================
# Default User Credentials
# ============================================
# These users are created on first startup
# Leave empty to skip creating that user role
# Change passwords after first login!

# Admin User
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=admin123

# Doctor User (optional)
DEFAULT_DOCTOR_USER=doctor
DEFAULT_DOCTOR_PASSWORD=doctor123

# Nurse User (optional)
DEFAULT_NURSE_USER=nurse
DEFAULT_NURSE_PASSWORD=nurse123

# Technician User (optional)
DEFAULT_TECH_USER=technician
DEFAULT_TECH_PASSWORD=tech123

